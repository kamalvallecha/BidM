run = "npm run dev"
hidden = [".config", "package-lock.json", "venv"]
modules = ["python-3.12", "cpp-clang14", "nodejs-20", "c-clang14"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "npm run dev"]
deploymentTarget = "cloudrun"

[env]
PYTHONPATH = "${PYTHONPATH}:${REPL_HOME}/backend" 
